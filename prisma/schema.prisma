generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["auth", "public"]
}

model School {
  id            String            @id @default(cuid())
  name          String
  createdAt     DateTime          @default(now()) @map("created_at")
  region        String?
  contactEmail  String?           @map("contact_email")
  licenses      License[]
  cycleGoals    SchoolCycleGoal[]
  schoolImpacts SchoolImpact[]
  schoolTopics  SchoolTopic[]

  @@map("schools")
  @@schema("public")
}

model License {
  id        String   @id @default(cuid())
  schoolId  String   @map("school_id")
  plan      String
  seats     Int
  status    String
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@map("licenses")
  @@schema("public")
}

model ContactMessage {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  email     String
  message   String
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  read      Boolean?  @default(false)
  responded Boolean?  @default(false)

  @@index([createdAt(sort: Desc)])
  @@index([email])
  @@map("contact_messages")
  @@schema("public")
}

model Profile {
  userId             String         @id @map("user_id")
  fullName           String         @map("full_name")
  role               String         @default("student")
  schoolId           String?        @map("school_id")
  xp                 Int            @default(0)
  level              Int            @default(1)
  nickname           String?        @unique
  reputation         Int            @default(0)
  postsCreated       Int            @default(0) @map("posts_created")
  commentsCreated    Int            @default(0) @map("comments_created")
  acceptedAnswers    Int            @default(0) @map("accepted_answers")
  createdAt          DateTime       @default(now()) @map("created_at")
  birthDate          DateTime?      @map("birth_date") @db.Timestamptz(6)
  isMinor            Boolean        @default(false) @map("is_minor")
  parentalOverride   Boolean        @default(false) @map("parental_override")
  ageVerifiedAt      DateTime?      @map("age_verified_at") @db.Timestamptz(6)
  avatar             Json?
  currentStreak      Int?           @default(0) @map("current_streak")
  longestStreak      Int?           @default(0) @map("longest_streak")
  lastActive         DateTime?      @map("last_active")
  bizcoins           Int?           @default(0)
  stripeCustomerId   String?        @unique @map("stripe_customer_id")
  subscriptionStatus String?        @default("none") @map("subscription_status")
  subscriptionId     String?        @map("subscription_id")
  planId             String?        @map("plan_id")
  subscriptionEnds   DateTime?      @map("subscription_ends")
  certificates       Certificate[]
  enrollments        Enrollment[]
  evidence_posts     EvidencePost[]
  progress           Progress[]

  @@index([schoolId], map: "idx_profiles_school")
  @@map("profiles")
  @@schema("public")
}

model Topic {
  id           String        @id(map: "courses_pkey") @default(cuid())
  title        String
  description  String?
  level        String
  isActive     Boolean       @default(true) @map("is_active")
  createdAt    DateTime      @default(now()) @map("created_at")
  bannerUrl    String?       @map("banner_url")
  icon         String?
  certificates Certificate[]
  courses      Course[]
  enrollments  Enrollment[]
  schoolTopics SchoolTopic[]

  @@map("topics")
  @@schema("public")
}

model SchoolTopic {
  schoolId  String  @map("school_id")
  topicId   String  @map("topic_id")
  isEnabled Boolean @default(true) @map("is_enabled")
  topic     Topic   @relation(fields: [topicId], references: [id], onDelete: Cascade, map: "school_courses_course_id_fkey")
  school    School  @relation(fields: [schoolId], references: [id], onDelete: Cascade, map: "school_courses_school_id_fkey")

  @@id([schoolId, topicId], map: "school_courses_pkey")
  @@map("school_topics")
  @@schema("public")
}

model Course {
  id          String    @id(map: "units_pkey") @default(cuid())
  topicId     String    @map("topic_id")
  title       String
  order       Int
  isLocked    Boolean   @default(false) @map("is_locked")
  createdAt   DateTime  @default(now()) @map("created_at")
  description String?
  icon        String?
  topic       Topic     @relation(fields: [topicId], references: [id], onDelete: Cascade, map: "units_course_id_fkey")
  lessons     Lesson[]
  sections    Section[]

  @@map("courses")
  @@schema("public")
}

model Section {
  id        String    @id @default(cuid())
  courseId  String?   @map("course_id")
  title     String
  order     Int
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  lessons   Lesson[]
  course    Course?   @relation(fields: [courseId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "sections_unit_id_fkey")

  @@index([courseId], map: "idx_sections_course")
  @@map("sections")
  @@schema("public")
}

model Lesson {
  id          String     @id @default(cuid())
  courseId    String?    @map("course_id")
  title       String
  contentType String     @map("content_type")
  order       Int
  xpReward    Int        @default(50) @map("xp_reward")
  createdAt   DateTime   @default(now()) @map("created_at")
  sectionId   String?    @map("section_id")
  duration    Int?       @default(5)
  section     Section?   @relation(fields: [sectionId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  course      Course?    @relation(fields: [courseId], references: [id], onDelete: Cascade, map: "lessons_unit_id_fkey")
  progress    Progress[]
  quizzes     Quiz[]

  @@index([sectionId], map: "idx_lessons_section")
  @@map("lessons")
  @@schema("public")
}

model LessonStep {
  id        String   @id @default(cuid())
  lessonId  String   @map("lesson_id")
  order     Int
  type      String
  title     String?
  body      String?
  data      Json?    @default("{}")
  xpReward  Int      @default(10) @map("xp_reward")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([lessonId], map: "idx_lesson_steps_lesson")
  @@map("lesson_steps")
  @@schema("public")
}

model LessonResource {
  id        String   @id @default(cuid())
  lessonId  String   @map("lesson_id")
  title     String
  url       String
  fileType  String   @map("file_type")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([lessonId], map: "idx_lesson_resources_lesson")
  @@map("lesson_resources")
  @@schema("public")
}

model TopicReview {
  id        String   @id(map: "course_reviews_pkey") @default(cuid())
  topicId   String   @map("topic_id")
  userId    String   @map("user_id")
  rating    Int
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, topicId], map: "course_reviews_user_id_course_id_key")
  @@map("topic_reviews")
  @@schema("public")
}

model UserNote {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  lessonId  String   @map("lesson_id")
  content   String
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([userId, lessonId])
  @@map("user_notes")
  @@schema("public")
}

model Quiz {
  id          String     @id @default(cuid())
  lessonId    String     @map("lesson_id")
  title       String
  passScore   Int        @map("pass_score")
  totalPoints Int        @map("total_points")
  createdAt   DateTime   @default(now()) @map("created_at")
  attempts    Attempt[]
  questions   Question[]
  lesson      Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@map("quizzes")
  @@schema("public")
}

model Question {
  id      String   @id @default(cuid())
  quizId  String   @map("quiz_id")
  type    String
  prompt  String
  order   Int
  options Option[]
  quiz    Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@map("questions")
  @@schema("public")
}

model Option {
  id         String   @id @default(cuid())
  questionId String   @map("question_id")
  text       String
  isCorrect  Boolean  @map("is_correct")
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("options")
  @@schema("public")
}

model Enrollment {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  topicId    String   @map("topic_id")
  enrolledAt DateTime @default(now()) @map("enrolled_at") @db.Timestamptz(6)
  topic      Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "enrollments_course_id_fkey")
  user       Profile  @relation(fields: [userId], references: [userId], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, topicId], map: "enrollments_user_id_course_id_key")
  @@map("enrollments")
  @@schema("public")
}

model Progress {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  lessonId    String    @map("lesson_id")
  percent     Int       @default(0)
  completedAt DateTime? @map("completed_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")
  starsEarned Int?      @default(0) @map("stars_earned")
  lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user        Profile   @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId, completedAt], map: "idx_progress_user_completed")
  @@map("progress")
  @@schema("public")
}

model Attempt {
  id          String    @id @default(cuid())
  userId      String?   @map("user_id") @db.Uuid
  quizId      String?   @map("quiz_id")
  score       Int
  completedAt DateTime? @default(now()) @map("completed_at") @db.Timestamptz(6)
  quiz        Quiz?     @relation(fields: [quizId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user        AuthUser? @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([quizId], map: "idx_attempts_quiz_id")
  @@index([userId], map: "idx_attempts_user_id")
  @@map("attempts")
  @@schema("public")
}

model Certificate {
  id       String   @id @default(cuid())
  userId   String   @map("user_id")
  topicId  String   @map("topic_id")
  url      String?
  issuedAt DateTime @default(now()) @map("issued_at") @db.Timestamptz(6)
  topic    Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "certificates_course_id_fkey")
  user     Profile  @relation(fields: [userId], references: [userId], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, topicId], map: "certificates_user_id_course_id_key")
  @@map("certificates")
  @@schema("public")
}

model ForumTag {
  id         String           @id @default(cuid())
  name       String
  slug       String           @unique
  usageCount Int              @default(0) @map("usage_count")
  createdAt  DateTime         @default(now()) @map("created_at")
  threadTags ForumThreadTag[]

  @@map("forum_tags")
  @@schema("public")
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model ForumThread {
  id                String           @id @default(cuid())
  title             String
  body              String
  authorId          String           @map("author_id")
  topicId           String           @map("topic_id")
  status            String?          @default("open")
  acceptedCommentId String?          @map("accepted_comment_id")
  score             Int              @default(0)
  viewCount         Int              @default(0) @map("view_count")
  commentCount      Int              @default(0) @map("comment_count")
  isPinned          Boolean          @default(false) @map("is_pinned")
  isHidden          Boolean          @default(false) @map("is_hidden")
  moderationStatus  String?          @default("approved") @map("moderation_status")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @default(now()) @updatedAt @map("updated_at")
  bookmarks         ForumBookmark[]
  comments          ForumComment[]
  follows           ForumFollow[]
  tags              ForumThreadTag[]

  @@index([authorId])
  @@index([topicId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@index([score(sort: Desc)])
  @@index([moderationStatus])
  @@map("forum_threads")
  @@schema("public")
}

model ForumThreadTag {
  threadId String      @map("thread_id")
  tagId    String      @map("tag_id")
  tag      ForumTag    @relation(fields: [tagId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  thread   ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([threadId, tagId])
  @@index([tagId])
  @@map("forum_thread_tags")
  @@schema("public")
}

model ForumComment {
  id               String         @id @default(cuid())
  threadId         String         @map("thread_id")
  parentCommentId  String?        @map("parent_comment_id")
  authorId         String         @map("author_id")
  body             String
  score            Int            @default(0)
  isHidden         Boolean        @default(false) @map("is_hidden")
  isAccepted       Boolean        @default(false) @map("is_accepted")
  moderationStatus String?        @default("approved") @map("moderation_status")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @default(now()) @updatedAt @map("updated_at")
  parentComment    ForumComment?  @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  replies          ForumComment[] @relation("CommentReplies")
  thread           ForumThread    @relation(fields: [threadId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([threadId])
  @@index([parentCommentId])
  @@index([authorId])
  @@index([createdAt])
  @@map("forum_comments")
  @@schema("public")
}

model ForumVote {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  targetType String   @map("target_type")
  targetId   String   @map("target_id")
  value      Int
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([userId, targetType, targetId])
  @@index([userId])
  @@index([targetType, targetId])
  @@index([targetType, targetId], map: "forum_votes_target_idx")
  @@map("forum_votes")
  @@schema("public")
}

model ForumBookmark {
  userId    String      @map("user_id")
  threadId  String      @map("thread_id")
  createdAt DateTime    @default(now()) @map("created_at")
  thread    ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([userId, threadId])
  @@index([threadId])
  @@map("forum_bookmarks")
  @@schema("public")
}

model ForumFollow {
  userId      String      @map("user_id")
  threadId    String      @map("thread_id")
  notifyEmail Boolean     @default(true) @map("notify_email")
  notifyInApp Boolean     @default(true) @map("notify_in_app")
  createdAt   DateTime    @default(now()) @map("created_at")
  thread      ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([userId, threadId])
  @@index([threadId])
  @@map("forum_follows")
  @@schema("public")
}

model ForumReport {
  id          String    @id @default(cuid())
  reporterId  String    @map("reporter_id")
  targetType  String    @map("target_type")
  targetId    String    @map("target_id")
  reason      String
  details     String?
  status      String?   @default("open")
  reviewedBy  String?   @map("reviewed_by")
  reviewedAt  DateTime? @map("reviewed_at")
  actionTaken String?   @map("action_taken")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([reporterId])
  @@index([targetType, targetId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@index([targetType, targetId], map: "forum_reports_target_idx")
  @@map("forum_reports")
  @@schema("public")
}

model ForumNotification {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  type      String
  data      Json
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([createdAt(sort: Desc)])
  @@index([readAt])
  @@map("forum_notifications")
  @@schema("public")
}

model ForumBadge {
  id               String           @id @default(cuid())
  name             String
  description      String?
  icon             String?
  requirementType  String           @map("requirement_type")
  requirementValue Int              @map("requirement_value")
  createdAt        DateTime         @default(now()) @map("created_at")
  userBadges       ForumUserBadge[]

  @@map("forum_badges")
  @@schema("public")
}

model ForumUserBadge {
  userId   String     @map("user_id")
  badgeId  String     @map("badge_id")
  earnedAt DateTime   @default(now()) @map("earned_at")
  badge    ForumBadge @relation(fields: [badgeId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([userId, badgeId])
  @@index([badgeId])
  @@map("forum_user_badges")
  @@schema("public")
}

model UserInventoryItem {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  productId   String   @map("product_id")
  purchasedAt DateTime @default(now()) @map("purchased_at")
  pricePaid   Int      @map("price_paid")

  @@unique([userId, productId], map: "user_inventory_unique_purchase")
  @@index([userId])
  @@index([userId], map: "idx_user_inventory_user")
  @@index([userId], map: "idx_user_inventory_user_id")
  @@map("user_inventory")
  @@schema("public")
}

model UserFollow {
  followerId  String    @map("follower_id")
  followingId String    @map("following_id")
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)

  @@id([followerId, followingId])
  @@map("user_follows")
  @@schema("public")
}

model Profession {
  id                  Int       @id @default(autoincrement())
  name                String    @db.VarChar(100)
  description         String?
  salary              Int
  taxes               Int
  homeMortgagePayment Int       @map("home_mortgage_payment")
  schoolLoanPayment   Int       @map("school_loan_payment")
  carLoanPayment      Int       @map("car_loan_payment")
  creditCardPayment   Int       @map("credit_card_payment")
  retailPayment       Int       @map("retail_payment")
  otherExpenses       Int       @map("other_expenses")
  childExpense        Int       @map("child_expense")
  homeMortgage        Int       @map("home_mortgage")
  schoolLoans         Int       @map("school_loans")
  carLoans            Int       @map("car_loans")
  creditCards         Int       @map("credit_cards")
  retailDebt          Int       @map("retail_debt")
  startingCash        Int       @map("starting_cash")
  startingSavings     Int       @map("starting_savings")
  createdAt           DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  players             Player[]

  @@map("professions")
  @@schema("public")
}

model GameSession {
  id              Int         @id @default(autoincrement())
  userId          String      @map("user_id") @db.Uuid
  status          String      @default("active") @db.VarChar(20)
  currentPhase    String?     @default("rat_race") @map("current_phase") @db.VarChar(20)
  startedAt       DateTime?   @default(now()) @map("started_at") @db.Timestamp(6)
  completedAt     DateTime?   @map("completed_at") @db.Timestamp(6)
  lastActivityAt  DateTime?   @default(now()) @map("last_activity_at") @db.Timestamp(6)
  totalTurns      Int?        @default(0) @map("total_turns")
  durationMinutes Int?        @map("duration_minutes")
  gameEvents      GameEvent[]
  users           AuthUser    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  players         Player[]

  @@index([status], map: "idx_game_sessions_status")
  @@index([userId], map: "idx_game_sessions_user_id")
  @@map("game_sessions")
  @@schema("public")
}

model Player {
  id                Int                @id @default(autoincrement())
  gameSessionId     Int                @map("game_session_id")
  userId            String             @map("user_id") @db.Uuid
  professionId      Int                @map("profession_id")
  cashOnHand        Int                @map("cash_on_hand")
  savings           Int?               @default(0)
  numChildren       Int?               @default(0) @map("num_children")
  currentPosition   Int?               @default(0) @map("current_position")
  isOnFastTrack     Boolean?           @default(false) @map("is_on_fast_track")
  hasEscapedRatRace Boolean?           @default(false) @map("has_escaped_rat_race")
  escapedAt         DateTime?          @map("escaped_at") @db.Timestamp(6)
  currentTurn       Int?               @default(1) @map("current_turn")
  totalIncome       Int?               @map("total_income")
  totalExpenses     Int?               @map("total_expenses")
  passiveIncome     Int?               @default(0) @map("passive_income")
  cashFlow          Int?               @map("cash_flow")
  createdAt         DateTime?          @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt         DateTime?          @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  gameEvents        GameEvent[]
  playerDoodads     PlayerDoodad[]
  playerInvestments PlayerInvestment[]
  playerLiabilities PlayerLiability[]
  gameSession       GameSession        @relation(fields: [gameSessionId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  profession        Profession         @relation(fields: [professionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users             AuthUser           @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([gameSessionId, userId])
  @@index([gameSessionId], map: "idx_players_game_session_id")
  @@index([userId], map: "idx_players_user_id")
  @@map("players")
  @@schema("public")
}

model OpportunityCard {
  id                Int                @id @default(autoincrement())
  type              String             @db.VarChar(50)
  name              String             @db.VarChar(200)
  description       String?
  downPayment       Int?               @map("down_payment")
  cost              Int
  mortgage          Int?
  cashFlow          Int?               @map("cash_flow")
  shares            Int?
  minSalePrice      Int?               @map("min_sale_price")
  maxSalePrice      Int?               @map("max_sale_price")
  bedrooms          Int?
  rarity            String?            @default("common") @db.VarChar(20)
  isActive          Boolean?           @default(true) @map("is_active")
  createdAt         DateTime?          @default(now()) @map("created_at") @db.Timestamp(6)
  isFastTrack       Boolean?           @default(false) @map("is_fast_track")
  playerInvestments PlayerInvestment[]

  @@map("opportunity_cards")
  @@schema("public")
}

model PlayerInvestment {
  id                Int             @id @default(autoincrement())
  playerId          Int             @map("player_id")
  opportunityCardId Int             @map("opportunity_card_id")
  purchasedAt       DateTime?       @default(now()) @map("purchased_at") @db.Timestamp(6)
  purchasePrice     Int             @map("purchase_price")
  downPaymentPaid   Int?            @map("down_payment_paid")
  mortgageAmount    Int?            @map("mortgage_amount")
  sharesOwned       Int?            @default(1) @map("shares_owned")
  isSold            Boolean?        @default(false) @map("is_sold")
  soldAt            DateTime?       @map("sold_at") @db.Timestamp(6)
  salePrice         Int?            @map("sale_price")
  currentCashFlow   Int?            @map("current_cash_flow")
  totalIncomeEarned Int?            @default(0) @map("total_income_earned")
  createdAt         DateTime?       @default(now()) @map("created_at") @db.Timestamp(6)
