  payload Json?
  @@map("audit_log_entries")
  @@schema("auth")
}

model AuthIdentity {
  id      String   @id @db.Uuid
  @@map("identities")
  @@schema("auth")
}

model AuthSession {
  id      String   @id @db.Uuid
  @@map("sessions")
  @@schema("auth")
}

model AuthRefreshToken {
  id      String   @id @db.Uuid
  @@map("refresh_tokens")
  @@schema("auth")
}

model AuthFlowState {
  id      String   @id @db.Uuid
  @@map("flow_state")
  @@schema("auth")
}

model AuthMfaAmrClaim {
  id      String   @id @db.Uuid
  @@map("mfa_amr_claims")
  @@schema("auth")
}

model AuthMfaChallenge {
  id      String   @id @db.Uuid
  @@map("mfa_challenges")
  @@schema("auth")
}

model AuthMfaFactor {
  id      String   @id @db.Uuid
  @@map("mfa_factors")
  @@schema("auth")
}

model AuthSamlProvider {
  id      String   @id @db.Uuid
  @@map("saml_providers")
  @@schema("auth")
}

model AuthSamlRelayState {
  id      String   @id @db.Uuid
  @@map("saml_relay_states")
  @@schema("auth")
}

model AuthSsoDomain {
  id      String   @id @db.Uuid
  @@map("sso_domains")
  @@schema("auth")
}

model AuthSsoProvider {
  id      String   @id @db.Uuid
  @@map("sso_providers")
  @@schema("auth")
}

model AuthSchemaMigration {
  version String @id @db.VarChar(255)
  @@map("schema_migrations")
  @@schema("auth")
}

model AuthInstance {
  id      String   @id @db.Uuid
  @@map("instances")
  @@schema("auth")
}

model UserSettings {
  userId               String   @id @map("user_id")
  language             String   @default("es")
  soundEffectsEnabled  Boolean  @default(true) @map("sound_effects_enabled")
  animationsEnabled    Boolean  @default(true) @map("animations_enabled")
  updatedAt            DateTime @updatedAt @map("updated_at")

  profile              Profile  @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("user_settings")
  @@schema("public")
}

model ImpactCycle {
  id        String   @id @default(cuid())
  name      String
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  isActive  Boolean  @default(false) @map("is_active")

  goals     SchoolCycleGoal[]

  @@map("impact_cycles")
  @@schema("public")
}

model SchoolCycleGoal {
  schoolId                String  @map("school_id")
  cycleId                 String  @map("cycle_id")
  targetActiveRate        Float   @default(0.70) @map("target_active_rate")
  targetModulesPerStudent Float   @default(1.0) @map("target_modules_per_student")

  school School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  cycle  ImpactCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  @@id([schoolId, cycleId])
  @@map("school_cycle_goals")
  @@schema("public")
}

model TransparencyReport {
  id        String   @id @default(cuid())
  title     String
  period    String
  reportUrl String   @map("report_url")
  badgeType String?  @map("badge_type")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("transparency_reports")
  @@schema("public")
}

model Simulator {
  id          String   @id @default(cuid())
  title       String
  description String?
  category    String?  // "PRESUPUESTO", "AHORRO", "CRÉDITO"
  iconName    String?  @map("icon_name")
  buttonColor String?  @map("button_color")
  slug        String   @unique
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  userSimulations UserSimulation[]

  @@map("simulators")
  @@schema("public")
}

model Notification {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  title     String    // Ej: "¡Nueva Racha!"
  message   String    @db.Text
  type      String    @default("system") // "achievement", "streak", "reward", "system", "level_up"
  priority  String    @default("normal") // "low", "normal", "high"
  link      String?   // A dónde llevar al usuario al hacer clic
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user Profile @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("notifications")
  @@schema("public")
}

model Achievement {
  id          String   @id @default(cuid())
  title       String   // Ej: "Ahorrador Experto"
  description String   @db.Text
  icon        String   // Ej: "trophy", "piggy-bank"
  category    String   @default("general") // "learning", "social", "financial", "consistency"
  xpReward    Int      @default(100) @map("xp_reward")
  createdAt   DateTime @default(now()) @map("created_at")

  userAchievements UserAchievement[]

  @@map("achievements")
  @@schema("public")
}

model UserAchievement {
  userId        String   @map("user_id")
  achievementId String   @map("achievement_id")
  earnedAt      DateTime @default(now()) @map("earned_at")

  user        Profile     @relation(fields: [userId], references: [userId], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@id([userId, achievementId])
  @@map("user_achievements")
  @@schema("public")
}

model UserSimulation {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  simulatorId    String   @map("simulator_id")
  simulationName String?  @map("simulation_name")
  data           Json     // Input and result data
  createdAt      DateTime @default(now()) @map("created_at")

  user      Profile   @relation(fields: [userId], references: [userId], onDelete: Cascade)
  simulator Simulator @relation(fields: [simulatorId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_simulations")
  @@schema("public")
}
